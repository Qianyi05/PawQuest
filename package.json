{
  "name": "pawquest-firebase-tests",
  "private": true,
  "scripts": {
    "test:firebase": "firebase emulators:exec --project demo-pawquest --only auth,firestore,storage \"./node_modules/.bin/mocha --timeout 15000 firebase_test/**/*.test.cjs\"",
    "test:firebase:rules": "mocha --timeout 15000 \"firebase_test/**/*.test.cjs\""
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.0.0",
    "mocha": "^11.0.0"
  }
}
