rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function validProfile(data) {
      return (!('nickname' in data) || data.nickname is string)
             && (!('bio' in data) || data.bio is string)
             && (!('city' in data) || data.city is string)
             && (!('age' in data) || data.age == null
                 || (data.age is int && data.age >= 1 && data.age <= 120));
    }

    // ---------------------------------------------------------------
    // User profiles: signed-in users may read public profile data; only the
    // owner may modify the root document.
    // ---------------------------------------------------------------
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && validProfile(request.resource.data);
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // By default, users may only read and write their own private subcollections.
    match /users/{userId}/{subcollection}/{documentId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Following uses mirrored documents. Both entries must be created or
    // deleted in the same batch to prevent forged one-sided relationships.
    match /users/{userId}/following/{targetId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && userId != targetId
                    && existsAfter(/databases/$(database)/documents/users/$(targetId)/followers/$(userId));
      allow delete: if request.auth != null
                    && request.auth.uid == userId
                    && !existsAfter(/databases/$(database)/documents/users/$(targetId)/followers/$(userId));
      allow update: if false;
    }

    match /users/{userId}/followers/{followerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == followerId
                    && userId != followerId
                    && existsAfter(/databases/$(database)/documents/users/$(followerId)/following/$(userId));
      allow delete: if request.auth != null
                    && request.auth.uid == followerId
                    && !existsAfter(/databases/$(database)/documents/users/$(followerId)/following/$(userId));
      allow update: if false;
    }

    // Notifications: another user may create a like/comment notification for
    // the recipient. Reading, marking as read, and deletion remain owner-only.
    // The creator must use their own actorId and an initial read value of false.
    match /users/{userId}/notifications/{notifId} {
      allow create: if request.auth != null
                    && request.resource.data.actorId == request.auth.uid
                    && request.resource.data.read == false;
    }

    // ---------------------------------------------------------------
    // Cities: publicly readable and never client-writable.
    // ---------------------------------------------------------------
    match /cities/{cityId} {
      allow read: if true;
      allow write: if false;
    }
    match /cities/{cityId}/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // ---------------------------------------------------------------
    // Posts: publicly readable; authors may edit or delete their own posts.
    // Other signed-in users may only update the likes and likedBy fields.
    // ---------------------------------------------------------------
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null && (
                      resource.data.authorId == request.auth.uid ||
                      request.resource.data.diff(resource.data)
                        .affectedKeys().hasOnly(['likes', 'likedBy'])
                    );
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;

      // Comments are publicly readable. Signed-in users may create comments,
      // and only the comment author may delete one.
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null
                      && request.resource.data.authorId == request.auth.uid;
        allow delete: if request.auth != null
                      && resource.data.authorId == request.auth.uid;
        allow update: if false;
      }
    }

    // ---------------------------------------------------------------
    // Weather and daily quests: currently readable and writable by signed-in
    // users; these rules can be narrowed when the final collection model settles.
    // ---------------------------------------------------------------
    match /dailyTasks/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /weatherTasks/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /weatherQuests/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /daily_tasks/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /weather_quests/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
