From 68b3f3bfbe07ca2d333c21af9cb5518c24c177b7 Mon Sep 17 00:00:00 2001
From: PawQuest Dev <dev@pawquest.local>
Date: Sat, 27 Jun 2026 12:33:42 +0000
Subject: [PATCH] chore: restore lints and use debugPrint

- analysis_options.yaml previously disabled avoid_print and several const/
  key/final lints; re-enable the full flutter_lints set so the analyzer can
  catch real issues
- Replace all remaining print() calls with debugPrint() (throttled and
  stripped in release builds)
---
 analysis_options.yaml             | 23 +++++++++++++++++------
 lib/providers/step_provider.dart  |  4 ++--
 lib/screens/home_screen.dart      |  2 +-
 lib/screens/world_map_screen.dart |  2 +-
 4 files changed, 21 insertions(+), 10 deletions(-)

diff --git a/analysis_options.yaml b/analysis_options.yaml
index 758a51f..300bcc2 100644
--- a/analysis_options.yaml
+++ b/analysis_options.yaml
@@ -1,10 +1,21 @@
+# This file configures the analyzer, which statically analyzes Dart code to
+# check for errors, warnings, and lints.
+#
+# The lints from `package:flutter_lints` are Flutter's recommended set. They
+# were previously disabled wholesale; they are now enabled so the analyzer can
+# actually catch problems. After pulling this change, run:
+#
+#     dart fix --apply        # auto-adds const / keys / final where missing
+#     flutter analyze         # confirm a clean report
+#
 include: package:flutter_lints/flutter.yaml
 
 linter:
   rules:
-    prefer_const_constructors: false
-    prefer_final_fields: false
-    use_key_in_widget_constructors: false
-    prefer_const_literals_to_create_immutables: false
-    prefer_const_constructors_in_immutables: false
-    avoid_print: false
\ No newline at end of file
+    # Logging should go through debugPrint, not print (re-enabled).
+    avoid_print: true
+    prefer_const_constructors: true
+    prefer_const_constructors_in_immutables: true
+    prefer_const_literals_to_create_immutables: true
+    prefer_final_fields: true
+    use_key_in_widget_constructors: true
diff --git a/lib/providers/step_provider.dart b/lib/providers/step_provider.dart
index 8c569fd..1856370 100644
--- a/lib/providers/step_provider.dart
+++ b/lib/providers/step_provider.dart
@@ -58,7 +58,7 @@ class StepProvider with ChangeNotifier {
   void startListening() {
     _subscription = Pedometer.stepCountStream.listen(
       _onStep,
-      onError: (error) => print('步数监听错误: $error'),
+      onError: (error) => debugPrint('步数监听错误: $error'),
     );
   }
 
@@ -122,7 +122,7 @@ class StepProvider with ChangeNotifier {
 
     await _dailyQuestProvider?.syncSteps(safeDailySteps);
 
-    print("🔥 Daily steps saved: $safeDailySteps for $dateStr");
+    debugPrint("🔥 Daily steps saved: $safeDailySteps for $dateStr");
   }
 
   /// Stop listener
diff --git a/lib/screens/home_screen.dart b/lib/screens/home_screen.dart
index 856a24b..334384c 100644
--- a/lib/screens/home_screen.dart
+++ b/lib/screens/home_screen.dart
@@ -56,7 +56,7 @@ class _HomeScreenState extends State<HomeScreen> {
   Future<List<City>> loadCities(BuildContext context) async {
     final jsonStr = await DefaultAssetBundle.of(context)
         .loadString('assets/config/cities.json');
-    print('✅ Loaded cities.json content: $jsonStr');
+    debugPrint('✅ Loaded cities.json content: $jsonStr');
     final List decoded = jsonDecode(jsonStr);
     return decoded.map((e) => City.fromJson(e)).toList();
   }
diff --git a/lib/screens/world_map_screen.dart b/lib/screens/world_map_screen.dart
index 38b48a6..3f027e8 100644
--- a/lib/screens/world_map_screen.dart
+++ b/lib/screens/world_map_screen.dart
@@ -81,7 +81,7 @@ class _WorldMapScreenState extends State<WorldMapScreen> {
 
           /// 城市徽章标记
           ...unlockedCities.map((city) {
-            print(city);
+            debugPrint('$city');
             double x = city['x'] / 1000 * screenWidth;
             double y = city['y'] / 1000 * screenHeight;
 
-- 
